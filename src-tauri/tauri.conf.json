{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Learn (Almost) Anything",
  "version": "0.4.2",
  "identifier": "com.legostin.learnanything",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Learn (Almost) Anything",
        "width": 1100,
        "height": 720
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$HOME/Library/Application Support/com.legostin.learnanything/**",
          "$HOME/.laa-course/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "sidecar/src": "sidecar/src",
      "sidecar/node_modules": "sidecar/node_modules",
      "sidecar/package.json": "sidecar/package.json"
    },
    "macOS": {
      "entitlements": "entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk3NzgxQzE4RkQwOEMyNDgKUldSSXdnajlHQng0bDh2dXJ3bGwvVjNOcFBJVnBYR0o4VmZSVzBPMm1ZK040QUYwd01CT1BJUlcK",
      "endpoints": [
        "https://github.com/legostin/learn-almost-anything/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
