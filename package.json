{
  "name": "learn-almost-anything",
  "private": true,
  "version": "0.3.27",
  "description": "Local desktop AI tutor that designs personalized courses on any topic — articles, interactive widgets, tests, homework with agent review, and TTS lectures. Uses your Claude Pro/Max or ChatGPT Plus/Pro subscription.",
  "keywords": [
    "ai-tutor",
    "ai-agents",
    "claude",
    "claude-code",
    "claude-agent-sdk",
    "codex",
    "openai-codex",
    "tauri",
    "tauri-app",
    "desktop-app",
    "course-generator",
    "personalized-learning",
    "education",
    "local-first",
    "mcp",
    "text-to-speech",
    "llm",
    "react",
    "rust",
    "typescript"
  ],
  "homepage": "https://github.com/legostin/learn-almost-anything",
  "repository": {
    "type": "git",
    "url": "https://github.com/legostin/learn-almost-anything.git"
  },
  "bugs": "https://github.com/legostin/learn-almost-anything/issues",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:sidecar": "node scripts/copy-sidecar.mjs",
    "build": "node scripts/copy-sidecar.mjs && node scripts/sign-sidecar-native.mjs && tsc && vite build && node scripts/verify-sidecar.mjs",
    "build:watch": "vite build --watch",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev --config src-tauri/tauri.dev.conf.json"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "codemirror": "^6.0.2",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "mermaid": "^11.15.0",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
